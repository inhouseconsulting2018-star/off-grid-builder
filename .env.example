# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local example: postgres://postgres:password@localhost:5432/offgrid_solar
# Neon example:  postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Random secret used to sign sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# NREL PVWatts v8 API key for real solar production data
# Free key at: https://developer.nrel.gov/signup/
# Without this key, calculations fall back to state-based peak sun hour estimates.
# NREL also provides a DEMO_KEY limited to ~50 requests/day for testing.
PVWATTS_API_KEY=

# Stripe Price ID for the one-time report unlock payment
# Leave blank to disable the payment gate (all reports will be freely accessible)
STRIPE_PRICE_ID=
