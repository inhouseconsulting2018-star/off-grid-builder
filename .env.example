# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local example: postgres://postgres:password@localhost:5432/offgrid_solar
# Neon example:  postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Random secret used to sign sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Admin bearer token for purchases/settings endpoints
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# ── Solar Data ────────────────────────────────────────────────────────────────

# NREL PVWatts v8 API key for real solar production data
# Free key at: https://developer.nrel.gov/signup/
# Without this key, calculations fall back to state-based peak sun hour estimates.
# NREL also provides a DEMO_KEY limited to ~50 requests/day for testing.
NREL_API_KEY=

# ── Stripe Paid Report Plans ──────────────────────────────────────────────────

# Stripe secret key. In Replit deployments this may be supplied by the Stripe
# integration instead. Never expose this to frontend code.
STRIPE_SECRET_KEY=

# Optional. Current frontend flow redirects to Stripe Checkout from the server
# and does not require this in browser code.
STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for launch pricing.
# Use a test-mode price while testing, and a live-mode price only after live
# Stripe is intentionally enabled.
STRIPE_HOMEOWNER_REPORT_PRICE_ID=
STRIPE_PROPERTY_PACK_PRICE_ID=
STRIPE_CONTRACTOR_ANNUAL_PRICE_ID=
STRIPE_CONTRACTOR_LIFETIME_PRICE_ID=

# Legacy fallback for Homeowner Full Report. Keep supported until old Replit
# secrets are removed.
STRIPE_PRICE_ID=

# Webhook signing secret for /api/stripe/webhook.
# Must match the Stripe webhook endpoint mode: test secret for test mode,
# live secret for live mode.
STRIPE_WEBHOOK_SECRET=

# Optional email delivery webhook for unlocked report links.
REPORT_EMAIL_WEBHOOK_URL=
